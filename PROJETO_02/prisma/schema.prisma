generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model tbl_contatos {
  id    Int    @id @unique(map: "id") @default(autoincrement())
  nome  String @db.VarChar(80)
  cpf   String @db.VarChar(18)
  email String @db.VarChar(255)
}
